# WannaV Sales管理システム - 環境変数設定例

# サーバーポート（Renderでは自動設定されるため不要）
PORT=3000

# JWT秘密鍵（必ず変更してください）
JWT_SECRET=your-super-secret-jwt-key-change-this

# データベースパス（省略可：デフォルトは ./data/wannav.db）
# DB_PATH=./data/wannav.db

# Google Sheets API認証情報（いずれか一方を設定）
# 方法1: サービスアカウントJSON（推奨）
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# 方法2: APIキー（スプレッドシートが公開されている場合）
# GOOGLE_API_KEY=your-google-api-key
